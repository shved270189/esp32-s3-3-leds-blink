# ===== ESP-IDF build output =====
# Regenerated by `idf.py build`.
build/

# ===== Generated project configuration =====
# The committed source of truth is sdkconfig.defaults; idf.py regenerates
# sdkconfig from it. Ignoring the generated files keeps diffs clean.
sdkconfig
sdkconfig.old

# ===== IDF Component Manager =====
# Downloaded managed components and their lockfile.
managed_components/
dependencies.lock

# ===== Tooling caches =====
.cache/

# ===== Editor / IDE =====
# The ESP-IDF VS Code extension writes machine-specific toolchain paths here.
.vscode/

# ===== OS =====
.DS_Store
